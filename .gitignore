# Secrets & local state — never commit
.env
.env.*
!.env.example
.elk-os-state.json

# Dependencies / build
node_modules/
dist/
*.log

# Portal — frozen archive of the pinned analog-elk-front-end commit plus its
# node_modules / .next build output. Reproduced on demand by
# portal/prepare-context.sh; never committed.
portal/.build/

# Claude-side OS rendered by `elk-os wire` — per-deployment, bakes absolute
# local paths into hook commands + run-claude.sh. Regenerated on demand; its
# .mcp.json references the token by env name only, but never commit this dir.
wire/

# Docker / data volumes (when bind-mounted locally)
data/
uploads/

# OS noise
.DS_Store

# Python bytecode
__pycache__/
*.pyc
