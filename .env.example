# ─────────────────────────────────────────────────────────────────────────────
# Elk OS — environment contract
#
# `elk-os init --profile <generic|analogelk>` generates a real `.env` from this
# file: it fills the AUTO-GENERATED secrets and leaves the EXTERNAL ones blank
# (those degrade gracefully until you supply them). Never commit `.env`.
#
# Format: plain KEY=VALUE, one per line, NO quotes. bin/elk-os and the wired
# hooks read values raw (quotes become part of the value), while docker compose
# strips double quotes — quoting a value makes the two parsers disagree.
# ─────────────────────────────────────────────────────────────────────────────

# ── Profile ──────────────────────────────────────────────────────────────────
# generic  = blank, unbranded agency-OS (synthetic "Demo Co" seed)
# analogelk = Analog Elk's own branding + demo data
ELK_OS_PROFILE=generic

# ── Deploy target ────────────────────────────────────────────────────────────
# local = localhost ports, no TLS · box = Caddy + real domain + auto-TLS
ELK_OS_TARGET=local
# Public hostname (box target only); Caddy provisions TLS for it.
ELK_OS_DOMAIN=

# ── AUTO-GENERATED on `init` (do not fill by hand) ───────────────────────────
POSTGRES_PASSWORD=
DIRECTUS_KEY=
DIRECTUS_SECRET=
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=
DIRECTUS_ADMIN_TOKEN=

# ── Internal wiring (defaults are fine for the single-box case) ──────────────
POSTGRES_USER=directus
POSTGRES_DB=directus
DIRECTUS_PORT=8056
PORTAL_PORT=3000
RAG_API_PORT=19100
DIRECTUS_URL=http://localhost:8056
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8056
# Marketing content reads committed JSON instead of live Directus when true.
USE_STATIC_FALLBACK=true

# ── Portal front-end (P4) ────────────────────────────────────────────────────
# The Next.js 16 portal (built from a pinned analog-elk-front-end commit) is
# bundled into up/down/logs by default and served at PORTAL_PORT. Set false to
# skip the heavy Next build (e.g. on a constrained box or for a Directus-only
# install). The image builds from portal/.build, a frozen archive prepared by
# portal/prepare-context.sh.
ELK_OS_WITH_PORTAL=true
# Local checkout of analog-elk-front-end used to build the portal image (only
# when building locally, i.e. ELK_OS_USE_PUBLISHED_IMAGES=false). Empty =
# default to a sibling checkout of this repo (../analog-elk-front-end). No
# checkout available? Set ELK_OS_WITH_PORTAL=false or use published images below.
PORTAL_SOURCE_REPO=

# ── Published images vs local build (P7 image-or-build toggle) ───────────────
# false (default) = build the portal + RAG images locally on first `up`.
# true            = PULL published images from a registry (GHCR) instead. Layers
#                   compose.images.portal.yaml / compose.images.rag.yaml (each only
#                   when its subsystem is enabled), which require PORTAL_IMAGE /
#                   RAG_IMAGE below to be set. Only useful once those images exist
#                   (i.e. a GitHub remote + a published release via publish-images.yml).
ELK_OS_USE_PUBLISHED_IMAGES=false
# Fully-qualified image refs, used only when ELK_OS_USE_PUBLISHED_IMAGES=true.
# e.g. ghcr.io/analogelk/elk-os-portal:0.1.0 and ghcr.io/analogelk/elk-os-rag-api:0.1.0
PORTAL_IMAGE=
RAG_IMAGE=

# ── RAG knowledge engine (P3) ────────────────────────────────────────────────
# The local RAG stack (Postgres + Qdrant + Redis + FastAPI) is bundled into
# `up`/`down`/`logs` by default. Set false to skip it (e.g. to avoid the Python
# image build on a constrained box). Embeddings are local (no API key needed).
ELK_OS_WITH_RAG=true
# RAG host ports (dev/local target only). Isolated from the core stack and from
# a host-running analog-elk-v3 engine so both can coexist.
RAG_POSTGRES_PORT=15433
QDRANT_PORT=16333
REDIS_PORT=16379
# The RAG KB database reuses POSTGRES_PASSWORD by default; set all three for a
# fully distinct credential / database name (RAG_POSTGRES_PASSWORD empty =
# fall back to POSTGRES_PASSWORD; shrinks blast radius if a credential leaks).
# The password only takes effect before the first `up` (initdb applies it).
RAG_POSTGRES_DB=analog_elk
RAG_POSTGRES_USER=analog_elk
RAG_POSTGRES_PASSWORD=
# Optional: protect the RAG write endpoints (/ingest) with an X-API-Key header.
RAG_API_KEY=

# ── EXTERNAL SaaS — optional, graceful degradation until set ─────────────────
# Billing (Stripe), analytics (Matomo), email (Resend), GitHub (release/CI).
# Empty = the relevant portal section shows "not configured" but the stack is green.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MATOMO_URL=
MATOMO_SITE_ID=
RESEND_API_KEY=
GITHUB_PAT=
