# ─────────────────────────────────────────────────────────────────────────────
# Elk OS — environment contract
#
# `elk-os init --profile <generic|analogelk>` generates a real `.env` from this
# file: it fills the AUTO-GENERATED secrets and leaves the EXTERNAL ones blank
# (those degrade gracefully until you supply them). Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Profile ──────────────────────────────────────────────────────────────────
# generic  = blank, unbranded agency-OS (synthetic "Demo Co" seed)
# analogelk = Analog Elk's own branding + demo data
ELK_OS_PROFILE=generic

# ── Deploy target ────────────────────────────────────────────────────────────
# local = localhost ports, no TLS · box = Caddy + real domain + auto-TLS
ELK_OS_TARGET=local
# Public hostname (box target only); Caddy provisions TLS for it.
ELK_OS_DOMAIN=

# ── AUTO-GENERATED on `init` (do not fill by hand) ───────────────────────────
POSTGRES_PASSWORD=
DIRECTUS_KEY=
DIRECTUS_SECRET=
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=
DIRECTUS_ADMIN_TOKEN=

# ── Internal wiring (defaults are fine for the single-box case) ──────────────
POSTGRES_USER=directus
POSTGRES_DB=directus
DIRECTUS_PORT=8056
PORTAL_PORT=3000
RAG_API_PORT=9100
DIRECTUS_URL=http://localhost:8056
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8056
# Marketing content reads committed JSON instead of live Directus when true.
USE_STATIC_FALLBACK=true

# ── EXTERNAL SaaS — optional, graceful degradation until set ─────────────────
# Billing (Stripe), analytics (Matomo), email (Resend), GitHub (release/CI).
# Empty = the relevant portal section shows "not configured" but the stack is green.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MATOMO_URL=
MATOMO_SITE_ID=
RESEND_API_KEY=
GITHUB_PAT=
