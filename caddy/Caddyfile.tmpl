# Elk OS — Caddy reverse proxy (box target)
# Caddy substitutes {$ELK_OS_DOMAIN} from the environment at load time and
# provisions Let's Encrypt certificates for all three hosts automatically.
#
# Routing (the full-stack box demo):
#   ${ELK_OS_DOMAIN}        → the static whitepaper landing (site/, mounted at /srv/site)
#   app.${ELK_OS_DOMAIN}    → the portal (the human surface)
#   cms.${ELK_OS_DOMAIN}    → Directus (the os_* board + native MCP at /mcp)
#
# All three hosts resolve to the box once the apex plus `app` + `cms`
# A/CNAME records point at it (e.g. musterr.dev, app.musterr.dev and
# cms.musterr.dev). The portal's
# NEXT_PUBLIC_DIRECTUS_URL + Directus PUBLIC_URL are pinned to the cms.* host by
# the prod compose overrides.
#
# NOTE: the app.* block proxies `portal:3000`. A Directus-only box (portal
# disabled via ELK_OS_WITH_PORTAL=false) should remove or repoint that block.

# Shared security headers for every public host. All muster subdomains
# terminate TLS at this same Caddy, so includeSubDomains is safe. `defer`
# applies the set-operations just before the response is written, so they
# overwrite anything an upstream (e.g. Directus' helmet defaults) emits
# instead of duplicating it, and they land on redirect responses too.
# No CSP in this wave.
(security_headers) {
	header {
		defer
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# The whitepaper landing (site/) on the apex.
{$ELK_OS_DOMAIN} {
	import security_headers
	encode zstd gzip

	root * /srv/site
	file_server

	log {
		output stdout
		format console
	}
}

# The portal (the human surface) on app.*
app.{$ELK_OS_DOMAIN} {
	import security_headers
	encode zstd gzip

	# The portal image is built from a real Next.js app whose "/" is that app's
	# own MARKETING homepage, not the portal. On a Muster deployment that page
	# is meaningless at best and misleading at worst, and "/" is exactly where
	# every "open the live demo" link lands. Send the bare root to the sign-in
	# door instead. Only the exact path "/" matches, so deep links
	# (/employee-portal/..., /client-portal/...) proxy through untouched.
	# 302, not 301: this is a demo-posture choice, and a permanent redirect
	# would be cached in visitors' browsers and painful to walk back.
	redir / /login 302

	reverse_proxy portal:3000

	log {
		output stdout
		format console
	}
}

# Directus — the shared os_* board and the native MCP endpoint — on cms.*
cms.{$ELK_OS_DOMAIN} {
	import security_headers
	encode zstd gzip

	# Hide the Directus Studio (admin app UI) from the public. Only the
	# human-facing app under /admin* is blocked; the REST/GraphQL/MCP API
	# (/items, /graphql, /auth, /assets, /files, /server, /mcp, /fields,
	# /users, …) stays fully open so the portal browser + MCP clients work.
	@studio path /admin /admin/*
	redir @studio https://{$ELK_OS_DOMAIN} 302

	reverse_proxy directus:8055

	log {
		output stdout
		format console
	}
}
