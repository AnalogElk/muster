# Analog Elk profile — env overrides merged into .env by
# `elk-os init --profile analogelk`. Analog Elk's own branding + demo data:
# the reference instance Mike uses as the reproducer.
# Only NON-secret overrides belong here; secrets are generated at init time.
ELK_OS_BRAND_NAME=Analog Elk
DIRECTUS_ADMIN_EMAIL=admin@analogelk.com
USE_STATIC_FALLBACK=true
