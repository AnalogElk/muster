# Generic profile — env overrides merged into .env by `elk-os init --profile generic`
# Blank, unbranded agency-OS seeded (in P2) with a synthetic "Demo Co".
# Only NON-secret overrides belong here; secrets are generated at init time.
ELK_OS_BRAND_NAME=Demo Co
DIRECTUS_ADMIN_EMAIL=admin@example.com
USE_STATIC_FALLBACK=true
