#!/usr/bin/env bash
# =============================================================================
# Elk OS — resumable phased installer CLI
# =============================================================================
# One-command, self-hostable repackaging of the Analog Elk agency-OS.
# Docker is the ONLY hard runtime dependency; everything else is POSIX bash +
# standard unix tools (curl, openssl, awk, grep, sed).
#
# Phases (ordered, idempotent, resumable via .elk-os-state.json):
#   init     generate secrets + write .env from .env.example
#   up       docker compose up the core (+ RAG engine), then bootstrap the admin token
#   migrate  (P2) apply os_* schema snapshot
#   seed     (P5) load profile seed data
#   wire     (P5) write CLAUDE.md + .mcp.json + hooks + memory seed
#   doctor   green/red health board (the runtime acceptance test)
#   down     stop the stack
#
# Secrets are NEVER echoed to stdout/stderr; they live only in .env (gitignored).
# =============================================================================
set -euo pipefail

# Secrets hygiene: every file this CLI creates (.env, .env.tmp during rewrites,
# state, wired configs) is owner-only. .env holds the DB password, Directus
# secret, admin password and admin token — it must never be group/world-readable
# on a shared box.
umask 077

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
ENV_FILE="${ROOT}/.env"
ENV_EXAMPLE="${ROOT}/.env.example"
STATE_FILE="${ROOT}/.elk-os-state.json"
COMPOSE_DIR="${ROOT}/compose"
PROFILES_DIR="${ROOT}/profiles"
BOOTSTRAP="${ROOT}/directus/bootstrap/mint-token.sh"
SCHEMA_SNAPSHOT="${ROOT}/directus/schema/snapshot.json"
SEED_DIR="${ROOT}/directus/seed"
CLAUDE_OS_DIR="${ROOT}/claude-os"

# ---------------------------------------------------------------------------
# Colour / logging helpers
# ---------------------------------------------------------------------------
if [ -t 1 ]; then
  RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
  CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

info()    { echo -e "${CYAN}[elk-os]${RESET} $*"; }
success() { echo -e "${GREEN}[elk-os]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[elk-os]${RESET} $*"; }
error()   { echo -e "${RED}[elk-os]${RESET} $*" >&2; }
die()     { error "$*"; exit 1; }

# ---------------------------------------------------------------------------
# Docker / compose detection
# ---------------------------------------------------------------------------
need_docker() {
  command -v docker >/dev/null 2>&1 || die "Docker is required but not on PATH. Install Docker Desktop."
  # Compose v2 is required: the compose files use spec features (top-level
  # `name:`, `!reset` overlay nulling, healthcheck-gated depends_on) that the
  # python docker-compose v1 cannot parse. Fail here with the fix instead of
  # with a YAML traceback mid-`up`.
  if ! docker compose version >/dev/null 2>&1; then
    if command -v docker-compose >/dev/null 2>&1; then
      case "$(docker-compose version --short 2>/dev/null || true)" in
        1.*) die "docker-compose v1 detected — Elk OS needs Compose v2 (the compose files use \`name:\` and \`!reset\`). Install the compose plugin: https://docs.docker.com/compose/install/" ;;
      esac
    else
      die "Docker Compose not found (neither 'docker compose' nor 'docker-compose'). Install the Compose v2 plugin: https://docs.docker.com/compose/install/"
    fi
  fi
}

if docker compose version >/dev/null 2>&1; then
  DC=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  DC=(docker-compose)
else
  DC=(docker compose)  # resolved lazily; need_docker/up will surface errors
fi

# Is the RAG knowledge-engine overlay enabled? (default on; toggle via .env)
with_rag() {
  local v; v="$(get_env ELK_OS_WITH_RAG)"; v="${v:-true}"
  [ "$v" = "true" ]
}

# Is the portal (Next.js front-end) overlay enabled? (default on; toggle via .env)
with_portal() {
  local v; v="$(get_env ELK_OS_WITH_PORTAL)"; v="${v:-true}"
  [ "$v" = "true" ]
}

# Pull published images (GHCR) instead of building locally? (default off)
# When on, the compose.images.{portal,rag}.yaml overlays drop the build sections
# and pin PORTAL_IMAGE / RAG_IMAGE. Each half is layered ONLY when its subsystem
# overlay is enabled, so ELK_OS_WITH_RAG=false never demands RAG_IMAGE (and vice
# versa). Only useful once those images exist (post-publish).
use_published_images() {
  local v; v="$(get_env ELK_OS_USE_PUBLISHED_IMAGES)"; v="${v:-false}"
  [ "$v" = "true" ]
}

# Build the compose invocation for the current target (reads .env).
# Overlays (RAG, portal) are appended consistently for every subcommand
# (up/down/logs) so the same service set is always addressed.
compose() {
  local target files
  target="$(get_env ELK_OS_TARGET)"; target="${target:-local}"
  files=(-f "${COMPOSE_DIR}/compose.yaml")
  if [ "$target" = "box" ]; then
    files+=(-f "${COMPOSE_DIR}/compose.prod.yaml")
  else
    files+=(-f "${COMPOSE_DIR}/compose.dev.yaml")
  fi
  # Image-or-build toggle: each images overlay is layered LAST *within its
  # subsystem's branch* so its `build: !reset null` wins, pulling the published
  # image instead of building. Gated on the subsystem being enabled — a combined
  # overlay used to declare BOTH services unconditionally, so ELK_OS_WITH_RAG=false
  # (or WITH_PORTAL=false) still demanded the disabled half's *_IMAGE var, or
  # created a stray container with no networks/env. Off by default (build locally).
  if with_rag; then
    files+=(-f "${COMPOSE_DIR}/compose.rag.yaml")
    if [ "$target" = "box" ]; then
      files+=(-f "${COMPOSE_DIR}/compose.rag.prod.yaml")
    else
      files+=(-f "${COMPOSE_DIR}/compose.rag.dev.yaml")
    fi
    if use_published_images; then
      files+=(-f "${COMPOSE_DIR}/compose.images.rag.yaml")
    fi
  fi
  if with_portal; then
    files+=(-f "${COMPOSE_DIR}/compose.portal.yaml")
    if [ "$target" = "box" ]; then
      files+=(-f "${COMPOSE_DIR}/compose.portal.prod.yaml")
    else
      files+=(-f "${COMPOSE_DIR}/compose.portal.dev.yaml")
    fi
    if use_published_images; then
      files+=(-f "${COMPOSE_DIR}/compose.images.portal.yaml")
    fi
  fi
  "${DC[@]}" --project-directory "$ROOT" --env-file "$ENV_FILE" "${files[@]}" "$@"
}

# The portal image builds from a frozen archive of a pinned analog-elk-front-end
# commit. Ensure that build context exists + is patched before any compose build.
ensure_portal_context() {
  with_portal || return 0
  # Pulling a published portal image needs no local build context.
  use_published_images && return 0
  local prep="${ROOT}/portal/prepare-context.sh"
  [ -f "$prep" ] || { warn "portal/prepare-context.sh missing — skipping portal prep."; return 0; }
  # prepare-context.sh writes .build/.elk-os-prepared (containing the pin) as its
  # LAST step. A missing or mismatched marker means a half-prepared context (a
  # prior prep died mid-patch) or a pin bump — re-prepare rather than silently
  # docker-building an unpatched tree.
  local pin marker
  pin="$(cat "${ROOT}/portal/PINNED_COMMIT" 2>/dev/null | tr -d '[:space:]' || true)"
  marker="$(cat "${ROOT}/portal/.build/.elk-os-prepared" 2>/dev/null | tr -d '[:space:]' || true)"
  if [ -z "$marker" ] || [ "$marker" != "$pin" ]; then
    info "Preparing the portal build context (pinned archive + self-host patches)…"
    # prepare-context.sh reads PORTAL_SOURCE_REPO from its environment; make the
    # .env knob work too.
    local src; src="$(get_env PORTAL_SOURCE_REPO)"
    if [ -n "$src" ]; then export PORTAL_SOURCE_REPO="$src"; fi
    bash "$prep" || die "Failed to prepare the portal build context.
Alternatives: in .env set ELK_OS_WITH_PORTAL=false (Directus-only install), or set
ELK_OS_USE_PUBLISHED_IMAGES=true + PORTAL_IMAGE/RAG_IMAGE to pull published images."
  fi
}

# ---------------------------------------------------------------------------
# .env helpers
# ---------------------------------------------------------------------------
get_env() {
  local key="$1"
  [ -f "$ENV_FILE" ] || { echo ""; return 0; }
  grep -E "^${key}=" "$ENV_FILE" 2>/dev/null | head -n1 | cut -d= -f2- || true
}

set_env() {
  local key="$1" val="$2"
  if grep -qE "^${key}=" "$ENV_FILE"; then
    awk -v k="$key" -v v="$val" 'BEGIN{FS="="} $1==k{print k"="v; next} {print}' \
      "$ENV_FILE" > "$ENV_FILE.tmp" && mv "$ENV_FILE.tmp" "$ENV_FILE"
  else
    printf '%s=%s\n' "$key" "$val" >> "$ENV_FILE"
  fi
}

# ---------------------------------------------------------------------------
# State helpers (.elk-os-state.json) — minimal JSON, no jq dependency
# ---------------------------------------------------------------------------
state_has() {
  [ -f "$STATE_FILE" ] || return 1
  grep -q "\"$1\"" "$STATE_FILE" 2>/dev/null
}

state_mark() {
  local phase="$1"
  state_has "$phase" && return 0
  local existing=""
  if [ -f "$STATE_FILE" ]; then
    existing="$(sed -n 's/.*"completed":\[\(.*\)\].*/\1/p' "$STATE_FILE")"
  fi
  local joined
  if [ -n "$existing" ]; then
    joined="${existing},\"${phase}\""
  else
    joined="\"${phase}\""
  fi
  printf '{"completed":[%s],"updated":"%s"}\n' "$joined" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$STATE_FILE"
}

# ---------------------------------------------------------------------------
# Secret masking for status output
# ---------------------------------------------------------------------------
mask_status() {
  # echoes "set (hidden)" or "(empty)" — never the value itself
  local val="$1"
  if [ -n "$val" ]; then echo "set (hidden)"; else echo "(empty)"; fi
}

# ---------------------------------------------------------------------------
# init
# ---------------------------------------------------------------------------
cmd_init() {
  local profile="generic" target="local" force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --profile) profile="${2:?--profile needs a value}"; shift 2 ;;
      --target)  target="${2:?--target needs a value}"; shift 2 ;;
      --force)   force=1; shift ;;
      *) die "Unknown init flag: $1" ;;
    esac
  done

  case "$profile" in generic|analogelk) ;; *) die "Unknown profile '$profile' (expected: generic|analogelk)";; esac
  case "$target"  in local|box) ;;        *) die "Unknown target '$target' (expected: local|box)";; esac

  [ -f "$ENV_EXAMPLE" ] || die ".env.example not found at $ENV_EXAMPLE"

  if [ -f "$ENV_FILE" ] && [ "$force" -ne 1 ]; then
    die ".env already exists. Refusing to clobber it. Re-run with --force to overwrite."
  fi

  command -v openssl >/dev/null 2>&1 || die "openssl is required to generate secrets."

  info "Writing .env from .env.example (profile=${profile}, target=${target})…"
  # --force must NOT rotate live secrets: postgres applies POSTGRES_PASSWORD
  # only at initdb, and the admin password/token must keep matching the DB —
  # regenerating them bricks an existing deployment. Snapshot them BEFORE the
  # copy (.env.example ships them blank) and re-apply after.
  local prev_pg prev_key prev_secret prev_pw prev_token
  prev_pg="$(get_env POSTGRES_PASSWORD)"
  prev_key="$(get_env DIRECTUS_KEY)"
  prev_secret="$(get_env DIRECTUS_SECRET)"
  prev_pw="$(get_env DIRECTUS_ADMIN_PASSWORD)"
  prev_token="$(get_env DIRECTUS_ADMIN_TOKEN)"
  if [ -f "$ENV_FILE" ]; then
    local env_backup="${ENV_FILE}.bak.$(date +%Y%m%d%H%M%S)"
    cp "$ENV_FILE" "$env_backup"
    chmod 600 "$env_backup"
    info "Backed up existing .env to $(basename "$env_backup")."
  fi
  cp "$ENV_EXAMPLE" "$ENV_FILE"
  chmod 600 "$ENV_FILE"   # owner-only: this file carries every stack secret

  set_env ELK_OS_PROFILE "$profile"
  set_env ELK_OS_TARGET  "$target"
  [ -n "$prev_pg" ]     && set_env POSTGRES_PASSWORD "$prev_pg"
  [ -n "$prev_key" ]    && set_env DIRECTUS_KEY "$prev_key"
  [ -n "$prev_secret" ] && set_env DIRECTUS_SECRET "$prev_secret"
  [ -n "$prev_pw" ]     && set_env DIRECTUS_ADMIN_PASSWORD "$prev_pw"

  # Auto-generate secrets (only if empty — re-running --force keeps existing).
  local k
  for k in POSTGRES_PASSWORD DIRECTUS_KEY DIRECTUS_SECRET DIRECTUS_ADMIN_PASSWORD; do
    if [ -z "$(get_env "$k")" ]; then
      set_env "$k" "$(openssl rand -hex 32)"
    fi
  done
  # Admin token is minted at bootstrap, never here (kept across --force re-runs).
  set_env DIRECTUS_ADMIN_TOKEN "$prev_token"

  # Merge profile defaults (non-secret overrides).
  local defaults="${PROFILES_DIR}/${profile}/env.defaults"
  if [ -f "$defaults" ]; then
    info "Merging profile defaults from profiles/${profile}/env.defaults…"
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in ''|\#*) continue ;; esac
      [ "${line#*=}" = "$line" ] && continue   # skip lines without '='
      set_env "${line%%=*}" "${line#*=}"
    done < "$defaults"
  fi

  state_mark init

  echo ""
  echo -e "${BOLD}Elk OS — .env written${RESET}"
  printf "  %-26s %s\n" "Profile"                 "$(get_env ELK_OS_PROFILE)"
  printf "  %-26s %s\n" "Target"                  "$(get_env ELK_OS_TARGET)"
  printf "  %-26s %s\n" "Brand"                   "$(get_env ELK_OS_BRAND_NAME)"
  printf "  %-26s %s\n" "Admin email"             "$(get_env DIRECTUS_ADMIN_EMAIL)"
  printf "  %-26s %s\n" "POSTGRES_PASSWORD"       "$(mask_status "$(get_env POSTGRES_PASSWORD)")"
  printf "  %-26s %s\n" "DIRECTUS_KEY"            "$(mask_status "$(get_env DIRECTUS_KEY)")"
  printf "  %-26s %s\n" "DIRECTUS_SECRET"         "$(mask_status "$(get_env DIRECTUS_SECRET)")"
  printf "  %-26s %s\n" "DIRECTUS_ADMIN_PASSWORD" "$(mask_status "$(get_env DIRECTUS_ADMIN_PASSWORD)")"
  printf "  %-26s %s\n" "DIRECTUS_ADMIN_TOKEN"    "minted at bootstrap (elk-os up)"
  echo ""
  success "init complete. Next: ${BOLD}./bin/elk-os up${RESET}"
}

# ---------------------------------------------------------------------------
# up
# ---------------------------------------------------------------------------
cmd_up() {
  need_docker
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  docker info >/dev/null 2>&1 || die "Docker daemon is not reachable. Start Docker and retry."

  local target; target="$(get_env ELK_OS_TARGET)"; target="${target:-local}"
  if [ "$target" = "box" ] && [ -z "$(get_env ELK_OS_DOMAIN)" ]; then
    die "ELK_OS_TARGET=box but ELK_OS_DOMAIN is empty. Set it in .env."
  fi

  if with_rag; then
    info "Starting the Elk OS core + RAG engine (target=${target})…"
    info "First run builds the RAG API image (Python + fastembed) and bakes the"
    info "local embedding model — this can take several minutes. Subsequent runs are cached."
  else
    info "Starting the Elk OS core (target=${target}, RAG disabled via ELK_OS_WITH_RAG=false)…"
  fi
  if with_portal; then
    ensure_portal_context
    info "The portal (Next.js 16) overlay is enabled. First run builds the portal"
    info "image (pnpm install + next build) — this can take several minutes."
    info "Disable with ELK_OS_WITH_PORTAL=false in .env."
  fi
  # `up` auto-builds any image that does not yet exist (portal, RAG API). Use
  # `./bin/elk-os rebuild-portal` to force a portal rebuild after a source change.
  compose up -d --remove-orphans

  # Wait for Directus to answer /server/health from the host.
  local url; url="$(get_env DIRECTUS_URL)"; url="${url:-http://localhost:8056}"
  info "Waiting for Directus at ${url}/server/health …"
  local tries=0 max=60
  until curl -sf -o /dev/null "${url}/server/health" 2>/dev/null; do
    tries=$((tries+1))
    if [ "$tries" -ge "$max" ]; then
      error "Directus did not become healthy within $((max*3))s."
      error "Inspect logs: ./bin/elk-os logs directus"
      state_mark up   # containers are up even if health lagged; doctor will gate
      exit 1
    fi
    sleep 3
  done
  success "Directus is healthy."
  state_mark up

  # Bootstrap: mint the admin static token (idempotent).
  info "Bootstrapping admin static token…"
  if bash "$BOOTSTRAP" "$ENV_FILE"; then
    state_mark bootstrap
    # The portal's instrumentation hook fail-fasts in production on a missing
    # DIRECTUS_TOKEN. On a first boot the portal container started BEFORE the
    # token was minted (empty token → crash loop). Recreate it now that .env
    # carries the real token so it boots cleanly with the wired credentials.
    if with_portal && [ -n "$(get_env DIRECTUS_ADMIN_TOKEN)" ]; then
      info "Recreating the portal with the freshly minted admin token…"
      compose up -d portal >/dev/null 2>&1 || warn "Could not recreate the portal — run ./bin/elk-os up again."
    fi
  else
    warn "Token bootstrap did not complete — re-run ./bin/elk-os up after Directus settles."
  fi

  echo ""
  success "Core is up. Next: ${BOLD}./bin/elk-os doctor${RESET}"
}

# ---------------------------------------------------------------------------
# down
# ---------------------------------------------------------------------------
cmd_down() {
  need_docker
  [ -f "$ENV_FILE" ] || die ".env not found — nothing to bring down."
  local with_volumes=0
  [ "${1:-}" = "--volumes" ] && with_volumes=1
  if [ "$with_volumes" -eq 1 ]; then
    warn "Bringing the stack down AND removing data volumes…"
    compose down --volumes
  else
    info "Stopping the Elk OS core (data volumes preserved)…"
    compose down
  fi
  success "Stack stopped."
}

# ---------------------------------------------------------------------------
# logs (convenience)
# ---------------------------------------------------------------------------
cmd_logs() {
  need_docker
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  if [ -n "${1:-}" ]; then compose logs -f "$1"; else compose logs -f; fi
}

# ---------------------------------------------------------------------------
# doctor — per-subsystem green/red board
# ---------------------------------------------------------------------------
DOCTOR_FAILED=0
doctor_row() {
  # $1 label  $2 state(0=OK green | 1=FAIL red | 2=WARN yellow)  $3 detail  $4 hint
  # WARN is a non-blocking degraded signal — it does NOT mark the board red.
  local label="$1" ok="$2" detail="$3" action="${4:-}"
  if [ "$ok" -eq 0 ]; then
    printf "  ${GREEN}●${RESET} %-22s ${GREEN}%-8s${RESET} %s\n" "$label" "OK" "$detail"
  elif [ "$ok" -eq 2 ]; then
    printf "  ${YELLOW}●${RESET} %-22s ${YELLOW}%-8s${RESET} %s\n" "$label" "WARN" "$detail"
    [ -n "$action" ] && printf "      ${DIM}→ %s${RESET}\n" "$action"
  else
    DOCTOR_FAILED=1
    printf "  ${RED}●${RESET} %-22s ${RED}%-8s${RESET} %s\n" "$label" "FAIL" "$detail"
    [ -n "$action" ] && printf "      ${DIM}→ %s${RESET}\n" "$action"
  fi
}

container_health() {
  # echoes: running|healthy  /  running|none  /  exited  /  absent ...
  local name="$1" state health
  if state=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null) && [ -n "$state" ]; then :; else echo "absent"; return; fi
  health=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$name" 2>/dev/null || echo "none")
  echo "${state}|${health}"
}

cmd_doctor() {
  echo ""
  echo -e "${BOLD}Elk OS — doctor${RESET}  ${DIM}$(date '+%Y-%m-%d %H:%M:%S')${RESET}"
  echo ""

  # 1. Docker daemon
  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    doctor_row "Docker daemon" 0 "reachable"
  else
    doctor_row "Docker daemon" 1 "not reachable" "Start Docker Desktop / the docker service, then retry."
    print_doctor_footer; return
  fi

  # 2. .env present
  if [ -f "$ENV_FILE" ]; then
    doctor_row ".env" 0 "present"
  else
    doctor_row ".env" 1 "missing" "Run ./bin/elk-os init --profile generic"
    print_doctor_footer; return
  fi

  # 3. Postgres container healthy
  local pg; pg="$(container_health elk-os-postgres)"
  case "$pg" in
    running\|healthy) doctor_row "Postgres container" 0 "running, healthy" ;;
    running\|none)    doctor_row "Postgres container" 0 "running (no healthcheck)" ;;
    running\|*)       doctor_row "Postgres container" 1 "running but ${pg##*|}" "Wait for the healthcheck, or ./bin/elk-os logs postgres" ;;
    absent)           doctor_row "Postgres container" 1 "not created" "Run ./bin/elk-os up" ;;
    *)                doctor_row "Postgres container" 1 "$pg" "Run ./bin/elk-os up ; ./bin/elk-os logs postgres" ;;
  esac

  # 4. Directus /server/health
  local url; url="$(get_env DIRECTUS_URL)"; url="${url:-http://localhost:8056}"
  local health_json
  if health_json=$(curl -sf --max-time 5 "${url}/server/health" 2>/dev/null); then
    if printf '%s' "$health_json" | grep -q '"status":"ok"'; then
      doctor_row "Directus health" 0 "${url} → status ok"
    else
      local st; st=$(printf '%s' "$health_json" | grep -o '"status":"[^"]*"' | head -n1 | cut -d'"' -f4)
      doctor_row "Directus health" 1 "${url} → status ${st:-unknown}" "Check dependencies: ./bin/elk-os logs directus"
    fi
  else
    doctor_row "Directus health" 1 "${url} unreachable" "Is the stack up? Run ./bin/elk-os up ; ./bin/elk-os logs directus"
  fi

  # 5. Admin static token (informational — green when minted)
  if [ -n "$(get_env DIRECTUS_ADMIN_TOKEN)" ]; then
    if curl -sf -o /dev/null --max-time 5 -H "Authorization: Bearer $(get_env DIRECTUS_ADMIN_TOKEN)" "${url}/users/me?fields=id" 2>/dev/null; then
      doctor_row "Admin API token" 0 "minted, authenticates (hidden)"
    else
      doctor_row "Admin API token" 1 "present but does not authenticate" "Re-run ./bin/elk-os up to re-mint."
    fi
  else
    doctor_row "Admin API token" 1 "not minted yet" "Run ./bin/elk-os up (bootstrap mints it)."
  fi

  # 6. RAG knowledge-engine /health (only when the overlay is enabled)
  if with_rag; then
    local rag_port rag_url rag_json
    rag_port="$(get_env RAG_API_PORT)"; rag_port="${rag_port:-9100}"
    rag_url="http://localhost:${rag_port}"
    if rag_json=$(curl -sf --max-time 5 "${rag_url}/health" 2>/dev/null); then
      local rstatus rreason rdocs rvecs detail
      # `|| true` keeps a no-match grep (e.g. reason:null) from tripping pipefail.
      rstatus=$(printf '%s' "$rag_json" | grep -o '"status":"[^"]*"' | head -n1 | cut -d'"' -f4 || true)
      rreason=$(printf '%s' "$rag_json" | grep -o '"reason":"[^"]*"' | head -n1 | cut -d'"' -f4 || true)
      rdocs=$(printf '%s'   "$rag_json" | grep -o '"doc_count":[0-9]*'    | head -n1 | cut -d: -f2 || true)
      rvecs=$(printf '%s'   "$rag_json" | grep -o '"vector_count":[0-9]*' | head -n1 | cut -d: -f2 || true)
      detail="${rag_url} → status ${rstatus:-unknown} (${rdocs:-0} docs, ${rvecs:-0} vectors)"
      if [ "$rstatus" = "ok" ]; then
        doctor_row "RAG API health" 0 "$detail"
      elif [ "$rstatus" = "degraded" ]; then
        # Preserve the engine's degraded-vs-down distinction: a yellow WARN, not red.
        doctor_row "RAG API health" 2 "${rag_url} → degraded (${rreason:-unknown}; ${rdocs:-0} docs, ${rvecs:-0} vectors)" \
          "Vectors missing/stale — semantic search is impaired. Ingest content or reindex the KB."
      else
        doctor_row "RAG API health" 2 "$detail" "Unexpected status — inspect ./bin/elk-os logs elkos-rag-api"
      fi
    else
      doctor_row "RAG API health" 1 "${rag_url} unreachable" "Is RAG up? ./bin/elk-os up ; ./bin/elk-os logs elkos-rag-api"
    fi
  fi

  # 7. Seeded data readable (os_tasks) — proves migrate + seed landed.
  #    Non-blocking WARN before seeding so a fresh, unseeded stack stays green.
  local stok; stok="$(get_env DIRECTUS_ADMIN_TOKEN)"
  if [ -n "$stok" ]; then
    local tasks_json
    if tasks_json=$(curl -sf --max-time 5 -H "Authorization: Bearer ${stok}" "${url}/items/os_tasks?limit=1&fields=id" 2>/dev/null); then
      if printf '%s' "$tasks_json" | grep -q '"id"'; then
        doctor_row "Seeded os_task" 0 "os_tasks readable (>=1 row)"
      else
        doctor_row "Seeded os_task" 2 "os_tasks present but empty" "Run ./bin/elk-os migrate && ./bin/elk-os seed"
      fi
    else
      doctor_row "Seeded os_task" 2 "os_tasks not queryable (schema not migrated?)" "Run ./bin/elk-os migrate && ./bin/elk-os seed"
    fi
  else
    doctor_row "Seeded os_task" 2 "no admin token yet" "Run ./bin/elk-os up (mints token), then migrate && seed"
  fi

  # 7b. Native Directus MCP server (the agent's door to the os_* board).
  #     Enabled by `wire` (settings.mcp_enabled). WARN (not red) when disabled
  #     so a valid pre-wire stack stays green; the loop only needs it post-wire.
  if [ -n "$stok" ]; then
    local mcp_code
    mcp_code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 5 \
      -X POST -H "Authorization: Bearer ${stok}" -H 'Content-Type: application/json' \
      -H 'Accept: application/json, text/event-stream' \
      -d '{"jsonrpc":"2.0","id":1,"method":"tools/list","params":{}}' \
      "${url%/}/mcp" 2>/dev/null || echo 000)
    case "$mcp_code" in
      200) doctor_row "Directus MCP" 0 "${url%/}/mcp → tools/list 200 (loop endpoint live)" ;;
      403) doctor_row "Directus MCP" 2 "${url%/}/mcp → disabled (settings.mcp_enabled=false)" "Run ./bin/elk-os wire to enable the native MCP server." ;;
      *)   doctor_row "Directus MCP" 2 "${url%/}/mcp → HTTP ${mcp_code}" "Native MCP not reachable — check ./bin/elk-os logs directus." ;;
    esac
  else
    doctor_row "Directus MCP" 2 "no admin token yet" "Run ./bin/elk-os up, then wire."
  fi

  # 8. Portal HTTP (only when the overlay is enabled). Green on HTTP 200 from
  #    the auth-free /login route (falls back to /). Red otherwise.
  #    Box target: the prod overlay publishes NO host port (Caddy fronts the
  #    portal on app.${ELK_OS_DOMAIN}), so probing localhost:3000 was a
  #    guaranteed false red on every healthy box (P6 follow-up #4). Probe the
  #    public app.* origin there instead — that also exercises Caddy + TLS.
  if with_portal; then
    local ptarget pdomain pport purl code
    ptarget="$(get_env ELK_OS_TARGET)"; ptarget="${ptarget:-local}"
    pdomain="$(get_env ELK_OS_DOMAIN)"
    if [ "$ptarget" = "box" ] && [ -n "$pdomain" ]; then
      purl="https://app.${pdomain}"
    else
      pport="$(get_env PORTAL_PORT)"; pport="${pport:-3000}"
      purl="http://localhost:${pport}"
    fi
    code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 8 "${purl}/login" 2>/dev/null || true)
    if [ "$code" != "200" ]; then
      # Fall back to the marketing root before declaring red.
      code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 8 "${purl}/" 2>/dev/null || true)
      if [ "$code" = "200" ]; then
        doctor_row "Portal HTTP" 0 "${purl}/ → HTTP 200"
      else
        doctor_row "Portal HTTP" 1 "${purl} → HTTP ${code:-no-response}" "Is the portal up/built? ./bin/elk-os logs portal"
      fi
    else
      doctor_row "Portal HTTP" 0 "${purl}/login → HTTP 200"
    fi
  fi

  print_doctor_footer
}

print_doctor_footer() {
  echo ""
  if [ "$DOCTOR_FAILED" -eq 0 ]; then
    success "All required subsystems green."
    exit 0
  else
    error "One or more subsystems are red (see → next actions above)."
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# migrate / seed shared helper
# ---------------------------------------------------------------------------
# The schema/data phases manipulate JSON (diff objects, row payloads, relation
# remapping). That is impractical in pure POSIX shell, so these two phases — and
# only these two — additionally require python3 (stdlib only, no pip installs).
# init/up/down/doctor stay docker-only.
require_python3() {
  command -v python3 >/dev/null 2>&1 || \
    die "migrate/seed require python3 (stdlib JSON handling). Install python3 and retry."
}

# ---------------------------------------------------------------------------
# migrate — apply the pruned os_* schema snapshot (idempotent diff + apply)
# ---------------------------------------------------------------------------
# Strategy (Directus schema API):
#   1. GET  /schema/snapshot         → read the target's *live* Directus version
#      and rewrite snapshot.directus to match (so a version-skewed image, e.g.
#      11.5.1 vs the 11.15.1 the snapshot was captured on, does not get rejected).
#   2. POST /schema/diff?force=true  → hash-stamped diff, or 204/empty if in sync.
#   3. POST /schema/apply            → mutate the schema with that diff.
# Re-running is a no-op once the target already matches (diff comes back empty).
cmd_migrate() {
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  require_python3
  [ -f "$SCHEMA_SNAPSHOT" ] || die "Schema snapshot not found at $SCHEMA_SNAPSHOT"

  local url tok
  url="$(get_env DIRECTUS_URL)"; url="${url:-http://localhost:8056}"
  tok="$(get_env DIRECTUS_ADMIN_TOKEN)"
  [ -n "$tok" ] || die "DIRECTUS_ADMIN_TOKEN is empty. Run ./bin/elk-os up to mint it first."

  info "Applying schema snapshot to ${url} (diff + apply, idempotent)…"
  if ELK_URL="$url" ELK_TOKEN="$tok" ELK_SNAPSHOT="$SCHEMA_SNAPSHOT" python3 - <<'PY'
import os, sys, json, urllib.request, urllib.error
url=os.environ['ELK_URL'].rstrip('/'); tok=os.environ['ELK_TOKEN']
snap=json.load(open(os.environ['ELK_SNAPSHOT']))

def req(method, path, body=None):
    data=json.dumps(body).encode() if body is not None else None
    r=urllib.request.Request(url+path, data=data, method=method,
        headers={'Authorization':'Bearer '+tok, 'Content-Type':'application/json'})
    try:
        with urllib.request.urlopen(r) as resp:
            raw=resp.read()
            return resp.getcode(), (json.loads(raw) if raw else None)
    except urllib.error.HTTPError as e:
        raw=e.read()
        try: j=json.loads(raw)
        except Exception: j={'errors':[{'message':raw.decode('utf-8','replace')[:300]}]}
        return e.code, j
    except urllib.error.URLError as e:
        print('[migrate] cannot reach %s: %s'%(url, e), file=sys.stderr); sys.exit(1)

# 1. align snapshot version to the live target (tolerate image/version skew)
code, cur = req('GET', '/schema/snapshot')
if code==200 and cur and 'data' in cur and cur['data'].get('directus'):
    snap['directus']=cur['data']['directus']

# 2. diff (force=true bypasses the version/vendor guard)
code, diff = req('POST', '/schema/diff?force=true', snap)
if code>=400:
    print('[migrate] diff failed (%d): %s'%(code, json.dumps(diff)[:400]), file=sys.stderr); sys.exit(1)
if code in (204,) or diff is None or not (isinstance(diff, dict) and diff.get('data')):
    print('[migrate] schema already in sync — no changes to apply.'); sys.exit(0)

# 3. apply the diff object ({hash, diff})
code, res = req('POST', '/schema/apply', diff['data'])
if code>=400:
    print('[migrate] apply failed (%d): %s'%(code, json.dumps(res)[:400]), file=sys.stderr); sys.exit(1)
print('[migrate] schema applied.')
PY
  then
    state_mark migrate
    success "migrate complete. Next: ${BOLD}./bin/elk-os seed${RESET}"
  else
    die "migrate failed (see errors above)."
  fi
}

# ---------------------------------------------------------------------------
# seed — load directus/seed/<profile>/*.json via the items REST API
# ---------------------------------------------------------------------------
# Idempotent upsert keyed on a per-collection natural key (name/email/version…).
# Seed rows use stable string ids (e.g. "org-democo") that are NOT valid INT/UUID
# primary keys, so the loader: drops "id", lets Directus mint the real PK,
# remaps any relational value that points at a known seed id, and filters each
# row down to columns that actually exist (schema drift / extra fields are
# silently dropped). Re-running skips rows whose natural key already resolves.
cmd_seed() {
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  require_python3
  [ -f "$SCHEMA_SNAPSHOT" ] || die "Schema snapshot not found at $SCHEMA_SNAPSHOT"

  local profile url tok dir
  profile="$(get_env ELK_OS_PROFILE)"; profile="${profile:-generic}"
  dir="${SEED_DIR}/${profile}"
  [ -d "$dir" ] || die "Seed dir not found for profile '${profile}': $dir"
  url="$(get_env DIRECTUS_URL)"; url="${url:-http://localhost:8056}"
  tok="$(get_env DIRECTUS_ADMIN_TOKEN)"
  [ -n "$tok" ] || die "DIRECTUS_ADMIN_TOKEN is empty. Run ./bin/elk-os up first."

  info "Seeding profile '${profile}' from ${dir} (idempotent upsert)…"
  if ELK_URL="$url" ELK_TOKEN="$tok" ELK_SEED_DIR="$dir" ELK_SCHEMA="$SCHEMA_SNAPSHOT" python3 - <<'PY'
import os, sys, json, glob, urllib.request, urllib.error, urllib.parse
url=os.environ['ELK_URL'].rstrip('/'); tok=os.environ['ELK_TOKEN']
seed_dir=os.environ['ELK_SEED_DIR']
kept={c['collection'] for c in json.load(open(os.environ['ELK_SCHEMA']))['collections']}

def req(method, path, body=None):
    data=json.dumps(body).encode() if body is not None else None
    r=urllib.request.Request(url+path, data=data, method=method,
        headers={'Authorization':'Bearer '+tok, 'Content-Type':'application/json'})
    try:
        with urllib.request.urlopen(r) as resp:
            raw=resp.read(); return resp.getcode(), (json.loads(raw) if raw else None)
    except urllib.error.HTTPError as e:
        raw=e.read()
        try: j=json.loads(raw)
        except Exception: j={'errors':[{'message':raw.decode('utf-8','replace')[:200]}]}
        return e.code, j
    except urllib.error.URLError as e:
        print('[seed] cannot reach %s: %s'%(url, e), file=sys.stderr); sys.exit(1)

# Natural key per collection (verified to be real columns in the pruned schema).
MATCH={'organizations':'name','contacts':'email','os_projects':'name',
       'os_sprints':'name','os_tasks':'name','releases':'version','repositories':'name'}
# Parents before children so relation remapping resolves.
ORDER=['organizations','contacts','os_projects','os_sprints','repositories','os_tasks','releases']

def resolve(stem):
    if stem in kept: return stem
    if 'os_'+stem in kept: return 'os_'+stem
    return None

files={}
for p in sorted(glob.glob(os.path.join(seed_dir,'*.json'))):
    stem=os.path.splitext(os.path.basename(p))[0]
    if stem.lower()=='readme': continue
    coll=resolve(stem)
    if not coll:
        print('[seed] skip %s (no matching kept collection)'%os.path.basename(p)); continue
    files[coll]=p
ordered=[c for c in ORDER if c in files]+[c for c in sorted(files) if c not in ORDER]

_fcache={}
def real_columns(coll):
    if coll in _fcache: return _fcache[coll]
    code,res=req('GET','/fields/'+coll)
    cols=set()
    if code==200 and res and 'data' in res:
        for f in res['data']:
            if f.get('schema') is not None:   # real DB column (skip o2m/m2m/group aliases)
                cols.add(f['field'])
    _fcache[coll]=cols; return cols

idmap={}; created=skipped=failed=0
for coll in ordered:
    rows=json.load(open(files[coll]))
    if isinstance(rows,dict): rows=[rows]
    cols=real_columns(coll)
    mf=MATCH.get(coll)
    if not mf or mf not in cols:
        mf='name' if 'name' in cols else ('email' if 'email' in cols else None)
    for row in rows:
        nk=row.get('id')
        # idempotency: does a row with this natural key already exist?
        realpk=None
        if mf and row.get(mf) is not None:
            q='/items/%s?limit=1&fields=id&filter[%s][_eq]=%s'%(
                coll, mf, urllib.parse.quote(str(row[mf])))
            code,res=req('GET',q)
            if code==200 and res and res.get('data'):
                realpk=res['data'][0]['id']
        if realpk is not None:
            if nk is not None: idmap[nk]=realpk
            skipped+=1; continue
        # build insert payload: real columns only, drop id, remap relation keys
        payload={}
        for k,v in row.items():
            if k=='id' or k not in cols: continue
            if isinstance(v,str) and v in idmap: v=idmap[v]
            payload[k]=v
        code,res=req('POST','/items/'+coll,payload)
        if code>=400:
            failed+=1
            print('[seed] FAIL %s: %s'%(coll, json.dumps(res)[:200]), file=sys.stderr); continue
        rid=res['data'].get('id') if res and 'data' in res else None
        if nk is not None and rid is not None: idmap[nk]=rid
        created+=1
print('[seed] created=%d skipped(existing)=%d failed=%d'%(created,skipped,failed))
sys.exit(1 if failed else 0)
PY
  then
    state_mark seed
    success "seed complete. Next: ${BOLD}./bin/elk-os doctor${RESET}"
  else
    die "seed failed (see errors above)."
  fi
}

# ---------------------------------------------------------------------------
# rebuild-portal — re-prepare the pinned context and rebuild the portal image
# ---------------------------------------------------------------------------
cmd_rebuild_portal() {
  need_docker
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  with_portal || die "Portal overlay disabled (ELK_OS_WITH_PORTAL=false). Enable it in .env first."
  local prep="${ROOT}/portal/prepare-context.sh"
  [ -f "$prep" ] || die "portal/prepare-context.sh missing."
  info "Re-preparing the portal build context (force re-extract + patch)…"
  bash "$prep" --force || die "prepare-context.sh failed."
  info "Rebuilding the portal image (no cache)…"
  compose build --no-cache portal || die "portal build failed."
  info "Recreating the portal container…"
  compose up -d portal
  success "portal rebuilt. Next: ${BOLD}./bin/elk-os doctor${RESET}"
}

# ---------------------------------------------------------------------------
# wire — P5: render the Claude-side OS into a deployment config directory
# ---------------------------------------------------------------------------
# Renders templates from claude-os/ into an output dir (default ./wire) so a
# buyer can `cd` there and run Claude Code already wired to THIS deployment's
# Directus + os_* board:
#   .mcp.json           → the native Directus MCP server (URL substituted; token
#                         left as the ${DIRECTUS_ADMIN_TOKEN} env reference — the
#                         secret is NEVER written into a file).
#   CLAUDE.md           → the profile's agency-OS constitution.
#   README.md           → how to use the wired directory.
#   run-claude.sh       → turnkey launcher (exports ONLY DIRECTUS_URL /
#                         DIRECTUS_ADMIN_TOKEN / ELK_OS_BRAND_NAME from the
#                         deployment .env — never sources it wholesale — then
#                         exec claude).
#   .claude/settings.json + .claude/hooks/  → SessionStart banner + os_tasks snapshot.
#   .claude/memory/     → MEMORY.md index + the auto-memory pattern note.
#
# It also enables Directus's native MCP server (the `mcp_enabled` project
# setting, off by default) so the wired .mcp.json works out of the box, then
# proves the loop by reading seeded os_tasks back through the same endpoint+token.
# Idempotent; marks `wire` in state. Secrets are never printed.

# Render a {{PLACEHOLDER}} template to a destination. `|` is the sed delimiter,
# and `\` / `&` are special in sed replacement text, so every substituted value
# is escaped first — a brand like "Smith & Co" or a path containing `|` must
# render literally, not corrupt the output (unescaped, `&` re-inserts the
# matched placeholder: "Smith {{BRAND_NAME}} Co").
sed_escape() { printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/&/\\&/g' -e 's/|/\\|/g'; }

render_tmpl() {
  local src="$1" dest="$2"
  sed \
    -e "s|{{DIRECTUS_URL}}|$(sed_escape "$WIRE_DIRECTUS_URL")|g" \
    -e "s|{{DIRECTUS_MCP_URL}}|$(sed_escape "$WIRE_MCP_URL")|g" \
    -e "s|{{BRAND_NAME}}|$(sed_escape "$WIRE_BRAND")|g" \
    -e "s|{{PROFILE}}|$(sed_escape "$WIRE_PROFILE")|g" \
    -e "s|{{ENV_FILE}}|$(sed_escape "$WIRE_ENV_FILE")|g" \
    -e "s|{{WIRE_DIR}}|$(sed_escape "$WIRE_DIR")|g" \
    -e "s|{{GENERATED_AT}}|$(sed_escape "$WIRE_GENERATED_AT")|g" \
    "$src" > "$dest"
}

cmd_wire() {
  [ -f "$ENV_FILE" ] || die ".env not found. Run ./bin/elk-os init first."
  [ -d "$CLAUDE_OS_DIR" ] || die "claude-os/ templates not found at $CLAUDE_OS_DIR"

  # --- flags ---
  local out_dir="${ROOT}/wire"
  while [ $# -gt 0 ]; do
    case "$1" in
      --dir) out_dir="${2:?--dir needs a path}"; shift 2 ;;
      *) die "Unknown wire flag: $1" ;;
    esac
  done

  # --- resolve substitution values from .env ---
  WIRE_PROFILE="$(get_env ELK_OS_PROFILE)"; WIRE_PROFILE="${WIRE_PROFILE:-generic}"
  WIRE_BRAND="$(get_env ELK_OS_BRAND_NAME)"; WIRE_BRAND="${WIRE_BRAND:-Elk OS}"
  WIRE_DIRECTUS_URL="$(get_env DIRECTUS_URL)"; WIRE_DIRECTUS_URL="${WIRE_DIRECTUS_URL:-http://localhost:8056}"
  WIRE_MCP_URL="${WIRE_DIRECTUS_URL%/}/mcp"
  WIRE_ENV_FILE="$ENV_FILE"
  WIRE_GENERATED_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  # absolute output dir (created below) for self-referential hook paths
  mkdir -p "$out_dir"
  WIRE_DIR="$(cd "$out_dir" && pwd)"

  local prof_dir="${CLAUDE_OS_DIR}/profiles/${WIRE_PROFILE}"
  [ -d "$prof_dir" ] || die "No claude-os profile templates for '${WIRE_PROFILE}' at $prof_dir"

  info "Wiring the Claude-side OS for profile '${WIRE_PROFILE}' → ${WIRE_DIR}"

  # --- 1. enable the native Directus MCP server (settings.mcp_enabled) ---
  local tok url; tok="$(get_env DIRECTUS_ADMIN_TOKEN)"; url="$WIRE_DIRECTUS_URL"
  if [ -n "$tok" ]; then
    local code
    code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 8 \
      -X PATCH -H "Authorization: Bearer ${tok}" -H 'Content-Type: application/json' \
      -d '{"mcp_enabled":true}' "${url%/}/settings" 2>/dev/null || echo 000)
    if [ "$code" = "200" ]; then
      success "Directus native MCP server enabled (settings.mcp_enabled=true)."
    else
      warn "Could not enable the Directus MCP setting (HTTP ${code}). The .mcp.json"
      warn "is still written; enable MCP in Directus Settings or re-run wire once up."
    fi
  else
    warn "DIRECTUS_ADMIN_TOKEN is empty — skipping MCP enable + loop verify."
    warn "Run ./bin/elk-os up to mint the token, then re-run ./bin/elk-os wire."
  fi

  # --- 2. render top-level files ---
  render_tmpl "${prof_dir}/CLAUDE.md.tmpl"    "${WIRE_DIR}/CLAUDE.md"
  render_tmpl "${CLAUDE_OS_DIR}/mcp.json.tmpl" "${WIRE_DIR}/.mcp.json"
  render_tmpl "${CLAUDE_OS_DIR}/README.tmpl.md" "${WIRE_DIR}/README.md"
  render_tmpl "${CLAUDE_OS_DIR}/run-claude.sh.tmpl" "${WIRE_DIR}/run-claude.sh"
  chmod +x "${WIRE_DIR}/run-claude.sh"

  # --- 3. .claude/ : settings (rendered) + hooks (verbatim) + memory (verbatim) ---
  mkdir -p "${WIRE_DIR}/.claude/hooks" "${WIRE_DIR}/.claude/memory"
  render_tmpl "${CLAUDE_OS_DIR}/settings.json.tmpl" "${WIRE_DIR}/.claude/settings.json"
  cp "${CLAUDE_OS_DIR}/hooks/session-banner.sh"     "${WIRE_DIR}/.claude/hooks/"
  cp "${CLAUDE_OS_DIR}/hooks/cms-task-snapshot.sh"  "${WIRE_DIR}/.claude/hooks/"
  chmod +x "${WIRE_DIR}/.claude/hooks/"*.sh
  cp "${CLAUDE_OS_DIR}/memory-seed/MEMORY.md"               "${WIRE_DIR}/.claude/memory/"
  cp "${CLAUDE_OS_DIR}/memory-seed/auto-memory-pattern.md"  "${WIRE_DIR}/.claude/memory/"

  echo ""
  echo -e "${BOLD}Wired files${RESET} (${WIRE_DIR})"
  printf "  %s\n" "CLAUDE.md                      ${WIRE_PROFILE} constitution"
  printf "  %s\n" ".mcp.json                      elk-os-cms → ${WIRE_MCP_URL}"
  printf "  %s\n" "README.md                      usage"
  printf "  %s\n" "run-claude.sh                  turnkey launcher"
  printf "  %s\n" ".claude/settings.json          SessionStart hook registration"
  printf "  %s\n" ".claude/hooks/                 session-banner.sh + cms-task-snapshot.sh"
  printf "  %s\n" ".claude/memory/                MEMORY.md + auto-memory-pattern.md"
  echo ""
  info "In .mcp.json the credential is the ${BOLD}\${DIRECTUS_ADMIN_TOKEN}${RESET} env"
  info "reference — the real token is never written into the wired directory."

  # --- 4. prove the loop: read seeded os_tasks back through the wired endpoint ---
  if [ -n "$tok" ]; then
    echo ""
    info "Loop check — reading os_tasks back through the wired Directus + token…"
    local tasks_json
    if tasks_json=$(curl -sf --max-time 8 -H "Authorization: Bearer ${tok}" \
        "${url%/}/items/os_tasks?fields=name,status,priority&sort=priority&limit=8" 2>/dev/null); then
      if printf '%s' "$tasks_json" | grep -q '"name"'; then
        if command -v python3 >/dev/null 2>&1; then
          # Payload via env, not stdin: the heredoc already owns stdin (program text).
          ELK_TASKS_JSON="$tasks_json" python3 - <<'PY'
import os, json
rows = json.loads(os.environ.get("ELK_TASKS_JSON", "")).get("data", [])
print("  \033[0;32m●\033[0m loop closed - a wired Claude session reads %d os_task(s):" % len(rows))
for r in rows:
    print("      [%s] %-36s %s" % (r.get("priority") or "--", (r.get("name") or "")[:36], r.get("status") or "?"))
PY
        else
          local n; n=$(printf '%s' "$tasks_json" | grep -o '"name"' | wc -l | tr -d ' ')
          success "loop closed — wired endpoint returns ${n} os_task row(s)."
        fi
      else
        warn "Loop check: os_tasks is empty. Run ./bin/elk-os migrate && ./bin/elk-os seed."
      fi
    else
      warn "Loop check: could not read os_tasks (is the stack up + migrated + seeded?)."
    fi
  fi

  state_mark wire
  echo ""
  success "wire complete. Launch: ${BOLD}cd ${WIRE_DIR} && ./run-claude.sh${RESET}  (or ./bin/elk-os doctor)"
}

# ---------------------------------------------------------------------------
# usage
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF

${BOLD}elk-os${RESET} — self-host agency-OS installer (resumable phased CLI)

${BOLD}Usage:${RESET}
  ./bin/elk-os <command> [flags]

${BOLD}Commands:${RESET}
  init [--profile generic|analogelk] [--target local|box] [--force]
                      Generate secrets + write .env from .env.example.
  up                  docker compose up the core (+ RAG engine), then mint the admin token.
  down [--volumes]    Stop the stack (keep data unless --volumes).
  doctor              Per-subsystem green/red health board (exits nonzero if red).
  logs [service]      Tail container logs (e.g. directus, elkos-rag-api).
  migrate             (P2) apply the pruned os_* schema snapshot (idempotent diff+apply).
  seed                (P2) load directus/seed/<profile>/*.json (idempotent upsert).
  rebuild-portal      (P4) re-prepare the pinned context + rebuild the portal image.
  wire [--dir PATH]   (P5) render CLAUDE.md + .mcp.json + hooks + memory into a
                      deployment config dir (default ./wire), enable the native
                      Directus MCP server, and prove the loop by reading os_tasks back.
  help                This message.

${BOLD}Quick start:${RESET}
  ./bin/elk-os init --profile generic
  ./bin/elk-os up
  ./bin/elk-os doctor

The RAG knowledge engine (Postgres + Qdrant + Redis + FastAPI, local
embeddings — no external inference) is bundled into up/down/logs by default.
Disable it by setting ELK_OS_WITH_RAG=false in .env (e.g. to skip the Python
image build). The RAG API is served at http://localhost:\${RAG_API_PORT:-9100}.

The portal (Next.js 16 front-end, built from a pinned analog-elk-front-end
commit) is bundled into up/down/logs by default and served at
http://localhost:\${PORTAL_PORT:-3000}. Disable it with ELK_OS_WITH_PORTAL=false
in .env (e.g. to skip the heavy Next build).

Docker is the only hard dependency. Secrets live only in .env (gitignored)
and are never printed.

EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
COMMAND="${1:-help}"; shift || true
case "$COMMAND" in
  init)    cmd_init "$@" ;;
  up)      cmd_up "$@" ;;
  down)    cmd_down "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  logs)    cmd_logs "$@" ;;
  migrate) cmd_migrate "$@" ;;
  seed)    cmd_seed "$@" ;;
  rebuild-portal) cmd_rebuild_portal "$@" ;;
  wire)    cmd_wire "$@" ;;
  help|--help|-h) usage ;;
  *) error "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
